---
import '5280-design-system/theme.css';
import '../styles/global.css';
import { Navbar, Footer } from '5280-design-system';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '52Eighty Creative — Creative with a heartbeat',
  description = 'Warm, faith-based branding & creative-storytelling agency. Video, storytelling, brand work.',
} = Astro.props;

// No dedicated newsletter page/section exists yet, so it's omitted here
// (rather than linked to a dead '#' anchor) until one is built.
// Every internal href is prefixed with `import.meta.env.BASE_URL`: the site
// deploys to a GitHub Pages project subpath (/52eighty/), where root-relative
// links resolve against the domain root and 404.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const SITE_LINKS = [
  { label: 'About', href: `${base}/about` },
  { label: 'Our Work', href: `${base}/work` },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <slot name="header">
        <header class="site-header">
          <div class="container">
            <Navbar
              links={SITE_LINKS}
              contactHref={`${base}/start`}
              chrome="flush"
              client:load
            />
          </div>
        </header>
      </slot>

      <main class="container">
        <slot />
      </main>

      <slot name="footer">
        <footer class="container">
          <Footer links={SITE_LINKS} client:load />
        </footer>
      </slot>
    </div>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    width: 100%;
    background: #ffffff;
    border-bottom: 1px solid var(--border);
  }
</style>
